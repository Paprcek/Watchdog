# --- Target Site Configuration ---
# The URL where the login form is submitted
TARGET_LOGIN_URL=https://example-b2b-site.com/login
# The starting point for the recursive crawler
TARGET_BASE_URL=https://example-b2b-site.com/all-products
# The main domain (used for reconstructing absolute URLs)
TARGET_DOMAIN=https://example-b2b-site.com

# --- Authentication ---
TARGET_USERNAME=your_b2b_username
TARGET_PASSWORD=your_b2b_password

# --- Database & Paths ---
# Use ./data for local runs or /app/data for Docker
DB_PATH=./data

# --- Email Notifications ---
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_RECEIVER=notification-recipient@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
